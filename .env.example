# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/safeguard_migas
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ───────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ML Model ───────────────────────────────────────────
MODEL_PATH=ml/ensemble_model.pkl
SCALER_PATH=ml/scaler.pkl
LABEL_ENCODER_PATH=ml/label_encoder.pkl

# ── Firebase (Push Notifications) ──────────────────────
FIREBASE_CREDENTIALS_PATH=ml/firebase_credentials.json

# ── App ────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","https://your-frontend.com"]
POLL_INTERVAL_SECONDS=5
DRIFT_CHECK_INTERVAL_SECONDS=60
